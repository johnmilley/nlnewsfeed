    <script type="text/javascript" id="admiral-script">
        
        if (window.admiral !== undefined) {
            window.admiral("targeting", "pause");
            document.addEventListener('pnIdProfileInit', () => {
                const profile = JSON.parse(localStorage.getItem('x-id')).data;
                const isAnonymous = !((profile && !!profile.email) || false);
                const isSubscribed = (profile && !!profile.adLight) || false;
                const isRegistered = !isAnonymous;

                window.admiral("targeting", "set", "isSubscribed", isSubscribed.toString());
                window.admiral("targeting", "set", "isRegistered", isRegistered.toString());
                window.admiral("targeting", "set", "isAnonymous", isAnonymous.toString());
                window.admiral("targeting", "ready");
            })
        }
    </script>



